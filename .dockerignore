# Docker ignore file for Gym Dorian API
# Prevents unnecessary files from being sent to Docker build context

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Testing and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Git files
.git/
.gitignore
.gitattributes

# Documentation and markdown (optional - keep if needed in container)
*.md
!README.md
docs/

# Environment files (security - use docker-compose environment)
.env
.env.*
*.env

# Database files (should be in volumes)
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/
*.out

# Temporary files
tmp/
temp/
*.tmp

# Build artifacts
build/
dist/
*.egg-info/
.eggs/

# OS files
Thumbs.db
.DS_Store

# Docker files (don't need these in the build context)
Dockerfile
docker-compose.yml
.dockerignore

# CI/CD files
.github/
.gitlab-ci.yml
.travis.yml

# Alembic - only exclude if not needed in container
# Keep alembic/ directory but exclude cache
alembic/__pycache__/

# Test data and fixtures (if not needed in production)
# app/tests/
# Uncomment above if you don't want tests in production image

# Development scripts
run_tests.sh
scripts/

# Type checking
.mypy_cache/
.pytype/
.pyre/

# Jupyter notebooks (if any)
*.ipynb
.ipynb_checkpoints/

# Node modules (if frontend exists)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Package manager files (keep requirements.txt)
poetry.lock
Pipfile.lock
pyproject.toml

# Large data files
*.csv
*.json
!workout.json
data/
