# Copy this file to `.env` and fill real values. Do NOT commit `.env`.
# Example environment variables for local development.

# PostgreSQL DSN (example). Replace with your credentials in your local `.env`.
DATABASE_URL=postgresql+psycopg2://<user>:<password>@localhost:5432/gym_db

# Application environment: development | staging | production
ENV_STATE=development

# JWT Authentication Settings
# IMPORTANT: Generate a secure secret key for production!
# Generate with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production-09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7

# JWT algorithm for token signing
ALGORITHM=HS256

# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
