{
  "info": {
    "name": "Gym Dorian - Dev",
    "_postman_id": "gym-dorian-dev-collection",
    "description": "Postman collection for local development (uses {{base_url}})",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "plan_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Ping - healthcheck",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/ping",
          "host": ["{{base_url}}"],
          "path": ["ping"]
        }
      },
      "response": []
    },
    {
      "name": "Log Workout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"date\": \"2025-12-13\",\n  \"exercises\": [\n    {\n      \"name\": \"Squat\",\n      \"sets\": [ { \"reps\": 5, \"weight\": 100 } ],\n      \"notes\": \"Warmup and working sets\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/workouts/log",
          "host": ["{{base_url}}"],
          "path": ["workouts","log"]
        }
      },
      "response": []
    },
    {
      "name": "Get Workout Plan",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/workouts/plan/{{plan_id}}",
          "host": ["{{base_url}}"],
          "path": ["workouts","plan","{{plan_id}}"]
        }
      },
      "response": []
    }
  ]
}
